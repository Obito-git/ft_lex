---
source: regex/src/ast.rs
expression: "(pattern_string, ast_result)"
---
- "[0-9]{2,4}"
- Ok:
    Repeat:
      node:
        BracketExpression:
          is_negated: false
          expr:
            - Range:
                start: "0"
                end: "9"
      lower_bound: 2
      upper_bound: 4
