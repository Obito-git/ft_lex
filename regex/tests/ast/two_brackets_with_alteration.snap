---
source: regex/src/ast.rs
expression: "(pattern_string, ast_result)"
---
- "[Z-a]|[c-f]"
- Ok:
    Alter:
      - BracketExpression:
          is_negated: false
          expr:
            - Range:
                start: Z
                end: a
      - BracketExpression:
          is_negated: false
          expr:
            - Range:
                start: c
                end: f
